<table class="table table--condensed" data-table-limit="true" data-table-max-height="auto">
  <thead>
    <tr>
      <th class="text--center"><span class="title title--small">Status</span></th>
      <th class="text--center"><span class="title title--small">Job #</span></th>
      <th><span class="title title--small">Description</span></th>
      {% unless is_compact == true %}
      <th><span class="title title--small">Started</span></th>
      <th><span class="title title--small">Duration</span></th>
      {% endunless %}
    </tr>
  </thead>
  <tbody>
    {% for build in builds %}

    {% assign build_status_icon = icon_build_unknown %}
    {% case build.result %}
    {% when 'SUCCESS' %}
    {% assign build_status_icon = icon_build_ok %}
    {% when 'FAILURE' %}
    {% assign build_status_icon = icon_build_fail %}
    {% when 'UNSTABLE' %}
    {% assign build_status_icon = icon_build_unstable %}
    {% when 'ABORTED', 'NOT_BUILT' %}
    {% assign build_status_icon = icon_build_aborted %}
    {% endcase %}

    {% assign duration_seconds = 0 %}
    {% if build.duration %}
    {% assign duration_seconds = build.duration | divided_by: 1000 %}
    {% endif %}

    <tr>
      <td class="px--2">
        <img class="image dark:bg--black rounded h--4 align--middle" src="data:image/svg+xml;base64,{{ build_status_icon | base64_encode }}" alt="{{ build.result | default: 'unknown' }}" />
        <span class="label label--small">{{ build.result | default: 'IN PROGRESS' }}</span>
      </td>
      <td class="text--center">
        <span class="label label--small">{{ build.number }}</span>
      </td>
      <td>
        <span class="label label--small" data-clamp="1">{{ build.description | default: 'N/A' }}</span>
      </td>
      {% unless is_compact == true %}
      <td>
        <span class="label label--small">{{ build.timestamp | divided_by: 1000 | l_date: '%y %b %l:%M %P', trmnl.user.locale }}</span>
      </td>
      <td>
        <span class="label label--small">
        {% if duration_seconds > 0 %}
        {% if duration_seconds >= 3600 %}
        {% assign duration_h = duration_seconds | divided_by: 3600 %}
        {% assign duration_h_rem = duration_seconds | modulo: 3600 %}
        {% assign duration_h_m = duration_h_rem | divided_by: 60 %}
        {{ duration_h }} hr {{ duration_h_m }} min
        {% elsif duration_seconds >= 60 %}
        {% assign duration_m = duration_seconds | divided_by: 60 %}
        {% assign duration_s = duration_seconds | modulo: 60 %}
        {{ duration_m }} min {{ duration_s }} sec
        {% else %}
        {{ duration_seconds }} sec
        {% endif %}
        {% else %}
        N/A
        {% endif %}
        </span>
      </td>
      {% endunless %}
    </tr>
    {% else %}
    <tr>
      <td class="description my--8" colspan="99">No builds returned from Jenkins.</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endtemplate %}

