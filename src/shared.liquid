<table class="table table--condensed" data-table-limit="true" data-table-max-height="auto">
  <thead>
    <tr>
      <th class="text--center"><span class="title title--small">S</span></th>
      <th class="text--center"><span class="title title--small">W</span></th>
      <th><span class="title title--small">Name</span></th>
      {% unless is_compact == true %}
      <th><span class="title title--small">Last Success</span></th>
      <th><span class="title title--small">Last Failure</span></th>
      <th><span class="title title--small">Last Duration</span></th>
      {% endunless %}
    </tr>
  </thead>
  <tbody>
    {% for job in jobs %}
    {% assign health = job.healthReport.first %}
    {% assign normalized_color = job.color | default: 'unknown' | remove: '_anime' %}
    {% assign status_icon = icon_job_unknown %}
    {% case normalized_color %}
    {% when 'blue' %}
    {% assign status_icon = icon_job_ok %}
    {% when 'red' %}
    {% assign status_icon = icon_job_fail %}
    {% when 'yellow' %}
    {% assign status_icon = icon_job_unstable %}
    {% when 'disabled' %}
    {% assign status_icon = icon_job_disabled %}
    {% endcase %}

    {% assign health_score = health.score | default: 0 %}
    {% assign health_icon = icon_health_stormy %}
    {% if health_score >= 80 %}
    {% assign health_icon = icon_health_sunny %}
    {% elsif health_score >= 61 %}
    {% assign health_icon = icon_health_partially_sunny %}
    {% elsif health_score >= 41 %}
    {% assign health_icon = icon_health_cloudy %}
    {% elsif health_score >= 21 %}
    {% assign health_icon = icon_health_raining %}
    {% endif %}

    {% assign duration_seconds = 0 %}
    {% if job.lastCompletedBuild and job.lastCompletedBuild.duration %}
    {% assign duration_seconds = job.lastCompletedBuild.duration | divided_by: 1000 %}
    {% elsif job.lastBuild and job.lastBuild.duration %}
    {% assign duration_seconds = job.lastBuild.duration | divided_by: 1000 %}
    {% endif %}

    <tr>
      <td class="w--8 px--2">
        <img class="image dark:bg--black rounded" src="data:image/svg+xml;base64,{{ status_icon | base64_encode }}" alt="{{ normalized_color }}" />
      </td>
      <td class="w--8 px--2">
        <img class="image dark:bg--black rounded" src="data:image/svg+xml;base64,{{ health_icon | base64_encode }}" alt="{{ health.description | default: 'health' }}" />
      </td>
      <td>
        <span class="label label--small" data-clamp="1">{{ job.name }}</span>
      </td>
      {% unless is_compact == true %}
      <td>
        <span class="label label--small">
        {% if job.lastSuccessfulBuild and job.lastSuccessfulBuild.timestamp %}
        {{ job.lastSuccessfulBuild.timestamp | divided_by: 1000 | l_date: '%y %b %l:%M %P', trmnl.user.locale }}
        {% if job.lastSuccessfulBuild.number %}
        <span class="label label--small label--outline ml--1">{{ job.lastSuccessfulBuild.number }}</div>
        {% endif %}
        {% else %}
        N/A
        {% endif %}
        </span>
      </td>
      <td>
        <span class="label label--small">
        {% if job.lastFailedBuild and job.lastFailedBuild.timestamp %}
        {{ job.lastFailedBuild.timestamp | divided_by: 1000 | l_date: '%y %b %l:%M %P', trmnl.user.locale }}
        {% if job.lastFailedBuild.number %}
        <span class="label label--small label--outline ml--1">{{ job.lastFailedBuild.number }}</span>
        {% endif %}
        {% else %}
        N/A
        {% endif %}
        </span>
      </td>
      <td>
        <span class="label label--small">
        {% if duration_seconds > 0 %}
        {% if duration_seconds >= 3600 %}
        {% assign duration_h = duration_seconds | divided_by: 3600 %}
        {% assign duration_h_rem = duration_seconds | modulo: 3600 %}
        {% assign duration_h_m = duration_h_rem | divided_by: 60 %}
        {{ duration_h }} hr {{ duration_h_m }} min
        {% elsif duration_seconds >= 60 %}
        {% assign duration_m = duration_seconds | divided_by: 60 %}
        {% assign duration_s = duration_seconds | modulo: 60 %}
        {{ duration_m }} min {{ duration_s }} sec
        {% else %}
        {{ duration_seconds }} sec
        {% endif %}
        {% else %}
        N/A
        {% endif %}
        </span>
      </td>
      {% endunless %}
    </tr>
    {% else %}
    <tr>
      <td class="description my--8" colspan="99">No jobs returned from Jenkins.</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endtemplate %}

