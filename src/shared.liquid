{% assign executors = IDX_0.computer %}
{% assign jobs = IDX_1.jobs %}
{% assign builds = IDX_2.builds %}

{% assign node_count = 0 %}
{% assign online_nodes = 0 %}
{% assign offline_nodes = 0 %}
{% assign total_executors = 0 %}
{% assign busy_executors = 0 %}

{% for executor in executors %}
{% assign node_count = node_count | plus: 1 %}
{% assign total_executors = total_executors | plus: executor.numExecutors %}
{% assign busy_executors = busy_executors | plus: executor.busyExecutors %}
{% if executor.offline or executor.temporarilyOffline %}
{% assign offline_nodes = offline_nodes | plus: 1 %}
{% else %}
{% assign online_nodes = online_nodes | plus: 1 %}
{% endif %}
{% endfor %}

{% assign idle_executors = total_executors | minus: busy_executors %}

{%- capture executor_status %}
{% if node_count > 0 %}
{{ online_nodes }}/{{ "node" | pluralize: node_count }} online, {{  busy_executors }}/{{ "executor" | pluralize: total_executors }} busy{% if offline_nodes > 0 %}, {{ offline_nodes }} offline{% endif %}
{% else %}
Jenkins CI
{% endif %}
{%- endcapture %}

{%# List of Jobs #%}
